# Medicover credentials
MEDICOVER_CARD_NUMBER=your_card_number
MEDICOVER_PASSWORD=yourpassword

# Search criteria
# Get IDs by using the Medicover website filters and checking network requests,
# or see the README for common values.
REGION_ID=204          # 204 = Warszawa
SPECIALTY_ID=9         # 9 = General Practitioner (Lekarz rodzinny)
START_DATE=2025-04-01  # Earliest acceptable appointment date (YYYY-MM-DD)

# Telegram notifications (required for alerts)
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_TOKEN=123456:ABC-xyz...
TELEGRAM_CHAT_ID=123456789

# Auto-book the first free slot found (default: false)
# WARNING: When true, an appointment will be booked without further confirmation.
AUTO_BOOK=false

# Polling mode (default: false = run once and exit)
POLL=false
POLL_INTERVAL_SEC=300

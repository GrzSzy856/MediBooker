# Medicover credentials
MEDICOVER_CARD_NUMBER=your_card_number
MEDICOVER_PASSWORD=yourpassword

# Search criteria
# Get IDs by using the Medicover website filters and checking network requests,
# or see the README for common values.
REGION_ID=204          # 204 = Warszawa
SPECIALTY_ID=9         # 9 = General Practitioner (Lekarz rodzinny)
# Earliest acceptable appointment date (YYYY-MM-DD), leave blank for no limit
START_DATE=2025-04-01
# Latest acceptable appointment date (YYYY-MM-DD), leave blank for no limit
END_DATE=

# Telegram notifications (optional)
# Set TELEGRAM_ENABLED=false to disable notifications entirely (no errors if token is invalid/missing)
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=123456:ABC-xyz...
TELEGRAM_CHAT_ID=123456789

# Optional filters (leave blank to disable)
# APPOINTMENT_TIME_RANGE: e.g. 16-24 (only slots from 16:00 to 23:59)
APPOINTMENT_TIME_RANGE=
# DOCTOR_NAME: e.g. Nowak Adam (partial match, case-insensitive, surname first)
DOCTOR_NAME=

# Auto-book the first free slot found (default: false)
# WARNING: When true, an appointment will be booked without further confirmation.
AUTO_BOOK=false

# Polling mode (default: false = run once and exit)
POLL=false
POLL_INTERVAL_SEC=300
